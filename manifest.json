{
  "manifest_version": 3,
  "name": "AlgoMonster FSRS Pro",
  "version": "2.0",
  "description": "FSRS spaced repetition with Auto-tagging, Heatmap Dashboard, and Notifications.",
  "permissions": [
    "storage",
    "activeTab",
    "notifications",
    "alarms",
    "downloads"
  ],
  "host_permissions": [
    "*://*.algo.monster/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.algo.monster/*"
      ],
      "js": [
        "fsrs.js",
        "content.js"
      ],
      "css": [
        "style.css"
      ]
    }
  ],
  "action": {
    "default_title": "AlgoMonster FSRS Dashboard",
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icon.png"
  }
}