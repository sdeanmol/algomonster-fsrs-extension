{
  "manifest_version": 3,
  "name": "AlgoMonster FSRS Pro",
  "version": "3.0",
  "description": "FSRS spaced repetition & SPA-safe Text Highlighter with DOM serialization.",
  "permissions": [
    "storage",
    "activeTab",
    "notifications",
    "alarms",
    "downloads",
    "webNavigation"
  ],
  "host_permissions": [
    "*://*.algo.monster/*",
    "*://*.systemdesignschool.io/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.algo.monster/*",
        "*://*.systemdesignschool.io/*"
      ],
      "js": ["content/fsrs.js", "content/content.js"],
      "css": ["content/style.css"]
    }
  ],
  "action": {
    "default_title": "AlgoMonster FSRS Dashboard",
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "128": "icons/icon.png"
  }
}