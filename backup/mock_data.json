        }
      },
      "id": "mark_1783316577007_mvc7p",
      "text": "This transforms the problem. We're no longer searching through distribution patterns. We're searching through possible time limits. For any time limit, we can quickly check if it works by simulating the greedy distribution.",
      "url": "https://algo.monster/problems/newspapers_split"
    },
    {
      "color": "#134515",
      "createdAt": 1783322894122,
      "highlightSource": {
