          "textOffset": 0
        }
      },
      "id": "mark_1783322894122_qubdu",
      "text": "Find the minimum time needed to read all newspapers. Since workers read in parallel, the total time equals the time taken by the slowest worker.",
      "url": "https://algo.monster/problems/newspapers_split"
    },
    {
      "color": "#134515",
      "createdAt": 1783402715865,
      "highlightSource": {
        "endMeta": {
