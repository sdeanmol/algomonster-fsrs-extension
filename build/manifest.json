{
  "manifest_version": 3,
  "name": "AlgoRecall: Coding Interview Spaced Repetition",
  "version": "3.0",
  "description": "Coding Interview Spaced Repetition Tracker & Highlighter for LeetCode & Codeforces - 100% free, local-first, no signup.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "notifications",
    "alarms",
    "downloads",
    "webNavigation",
    "scripting"
  ],
  "host_permissions": [
    "*://*.algo.monster/*",
    "*://*.systemdesignschool.io/*",
    "*://*.codeforces.com/*",
    "*://*.leetcode.com/*",
    "*://*.codechef.com/*",
    "*://*.atcoder.jp/*",
    "*://*.hackerrank.com/*",
    "*://*.hackerearth.com/*",
    "*://*.codewars.com/*",
    "*://*.codingame.com/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "cross_origin_embedder_policy": {
    "value": "require-corp"
  },
  "cross_origin_opener_policy": {
    "value": "same-origin"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.algo.monster/*",
        "*://*.systemdesignschool.io/*",
        "*://*.codeforces.com/*",
        "*://*.leetcode.com/*",
        "*://*.codechef.com/*",
        "*://*.atcoder.jp/*",
        "*://*.hackerrank.com/*",
        "*://*.hackerearth.com/*",
        "*://*.codewars.com/*",
        "*://*.codingame.com/*"
      ],
      "js": [
        "features/common/logger.js",
        "features/common/marked.min.js",
        "features/common/markdown.js",
        "features/tracker/scheduler/scheduler.js",
        "dist/fsrsScheduler.bundle.js",
        "content/state.js",
        "content/utils.js",
        "features/highlighter/highlighter.js",
        "content/notifications.js",
        "features/tracker/tracker.js",
        "content/content.js"
      ],
      "css": ["features/highlighter/style.css"]
    }
  ],
  "action": {
    "default_title": "AlgoRecall Dashboard",
    "default_popup": "features/dashboard/popup/popup.html"
  },
  "icons": {
    "128": "icons/icon.png"
  }
}